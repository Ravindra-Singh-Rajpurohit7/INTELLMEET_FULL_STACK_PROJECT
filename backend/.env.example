# ═══════════════════════════════════════════
# IntellMeet Backend — Environment Variables

# ═══════════════════════════════════════════

# ─── SERVER ─────────────────────────────────
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ───────────────────────────────
MONGODB_URI=your_mongodb_connection_string_here

# ─── JWT SECRETS ────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret_minimum_64_chars_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_different_from_access
REFRESH_TOKEN_EXPIRY=7d

# ─── CORS ───────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── REDIS ──────────────────────────────────
REDIS_URL=NOT_CONFIGURED

# ─── CLOUDINARY ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ─── AI API KEYS ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── EMAIL ──────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_address_here
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM="IntellMeet <your_email_address_here>"
